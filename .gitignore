# Dependencies
node_modules/
*/node_modules/
**/.venv/

# Build artifacts
*/dist/
*/build/
contracts/out/

# Compiled contract artifacts — committed so CI can package them into releases
# deploy/compiled/  <-- intentionally tracked

# Secrets — never commit
deploy/.seed
deploy/.bridge-seed
*.seed
*.env
.env*

# Deployment state — deploy/deployment.json is intentionally tracked (just contract addresses, not sensitive)
deployment.json

# LevelDB wallet state
midnight-level-db/
*/midnight-level-db/

# Model weights
provider/models/*
!provider/models/.cache/huggingface/.gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
*.whl

# Logs
*.log

# Build output
dist/
.build-tmp/

# OS
.DS_Store
